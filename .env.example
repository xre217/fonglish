# Quality preset: fast | balanced | accurate
# balanced = whisper-base + llama3 (8B) — better accuracy, still local/$0
# Explicit OLLAMA_MT_MODEL / WHISPER_MODEL always override the preset.
FONGLISH_QUALITY=balanced

# Ollama — local translation (no API key)
# https://ollama.com
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MT_MODEL=llama3:latest

# Local STT (Whisper via Transformers.js)
# WHISPER_MODEL=Xenova/whisper-base
# STT_SPEECH_RMS=500
# STT_SILENCE_MS=700

# Translate interim (partial) STT? Default off — finals only (less flicker, better MT).
# MT_ON_PARTIAL=0

# Optional glossary: comma-separated "Term" or "Source=Target" hints for MT
# MT_GLOSSARY=Fonglish,WebRTC,Ollama

# Host TTS (spoken interpretation) — macOS `say` + afconvert
# TTS_ENABLED=1
# TTS_ENGINE=say
# TTS_RATE=200
# Per-language voice overrides (macOS say -v names):
# TTS_VOICE_EN=Samantha
# TTS_VOICE_ES=Monica
# TTS_VOICE_FR=Thomas
# TTS_VOICE_DE=Anna
# TTS_VOICE_ZH=Ting-Ting
# TTS_VOICE_JA=Kyoko
# TTS_VOICE_PT=Joana
# TTS_VOICE_KO=Yuna

# Gateway
GATEWAY_PORT=8787
GATEWAY_HOST=0.0.0.0

# Web (Next.js)
# Use 127.0.0.1 (not localhost) on Windows to avoid IPv6 ::1 mismatch.
# For a second PC on the LAN, set this to ws://<gateway-host-ip>:8787
NEXT_PUBLIC_GATEWAY_URL=ws://127.0.0.1:8787
NEXT_PUBLIC_GATEWAY_PORT=8787
# Optional: invite links use this origin instead of localhost (for Windows peers)
# NEXT_PUBLIC_SHARE_ORIGIN=https://fonglish.vercel.app
